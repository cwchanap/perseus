{
	"$schema": "https://turbo.build/schema.json",
	"ui": "tui",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["build/**", ".svelte-kit/**", "dist/**"],
			"env": ["NODE_ENV", "PUBLIC_API_BASE"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"preview": {
			"cache": false,
			"persistent": true
		},
		"start": {
			"dependsOn": ["build"],
			"cache": false,
			"persistent": true
		},
		"check": {
			"outputs": []
		},
		"check:watch": {
			"cache": false,
			"persistent": true
		},
		"lint": {
			"outputs": []
		},
		"test": {
			"outputs": ["test-results/**"]
		},
		"test:unit": {
			"outputs": ["coverage/**"]
		},
		"test:e2e": {
			"outputs": ["test-results/**", "playwright-report/**"]
		},
		"pulumi:preview": {
			"dependsOn": ["build"],
			"cache": false,
			"outputs": []
		},
		"pulumi:up": {
			"dependsOn": ["build"],
			"cache": false,
			"outputs": [],
			"passThroughEnv": [
				"PULUMI_CONFIG_PASSPHRASE",
				"PULUMI_CONFIG_PASSPHRASE_FILE",
				"CLOUDFLARE_API_TOKEN"
			]
		}
	}
}
